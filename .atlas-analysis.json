  "keyFeatures": [
    "Remote attestation for TEEs (TDX, SGX, SNP, CCA, IBM SE, NVIDIA, TPM, and more)",
    "Secret and key delivery to confidential guests via RCAR protocol",
    "OPA/Rego-based attestation and resource access policies",
    "Flexible deployment: all-in-one binary, Docker Compose, or Kubernetes",
    "Reference value management for software supply chain verification",
    "Multiple KMS backends: local filesystem, Aliyun KMS, HashiCorp Vault",
    "Background Check and Passport attestation modes (RATS architecture)",
    "EAR (EAT Attestation Results) token issuance in JWT format"
  ],
  "publicApiSurface": [
    "POST /kbs/v0/auth — Initiate attestation (RCAR Request step)",
    "POST /kbs/v0/attest — Submit TEE evidence (RCAR Attestation step)",
    "GET /kbs/v0/resource/{repository}/{type}/{tag} — Retrieve secret resource (JWE encrypted)",
    "POST /kbs/v0/resource/{repository}/{type}/{tag} — Register secret resource",
    "POST /kbs/v0/attestation-policy — Set OPA attestation policy",
    "POST /kbs/v0/resource-policy — Set resource access policy",
    "GET /kbs/v0/resource-policy — Get current resource policy",
    "POST /kbs/v0/reference-value — Register reference value",
    "GET /kbs/v0/reference-value/{id} — Query reference value",
    "GET /metrics — Prometheus metrics endpoint",
    "gRPC AttestationService.AttestationEvaluate — Evaluate TEE evidence",
    "gRPC AttestationService.SetAttestationPolicy — Upload attestation policy",
    "gRPC ReferenceValueProviderService.RegisterReferenceValue — Register provenance",
    "gRPC ReferenceValueProviderService.QueryReferenceValues — Query reference values"
  ]
}
